# Oracle Forge Environment Configuration
# Copy this to .env and fill in your values
# Never commit .env to version control

# ===========================================
# REQUIRED: LLM API Configuration
# ===========================================
# Choose ONE of the following API keys:

# Option 1: OpenRouter (recommended)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-pro-preview

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===========================================
# REQUIRED: Database Connections
# ===========================================

# PostgreSQL (for BookReview dataset)
POSTGRES_URL=postgresql://postgres:teampalm@127.0.0.1:5435/bookreview_db
PG_HOST=127.0.0.1
PG_PORT=5435
PG_DATABASE=bookreview_db
PG_USER=postgres
PG_PASSWORD=teampalm

# MongoDB (for Yelp dataset)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=yelp_db

# ===========================================
# OPTIONAL: Dataset Configuration
# ===========================================

# Root directory for DAB datasets
DAB_DATASET_ROOT=/home/bethel/DataAgentBench

# DuckDB MCP server (for user_database)
DUCKDB_MCP_URL=http://127.0.0.1:8001

# Google Toolbox MCP server (PostgreSQL/MongoDB/SQLite)
TOOLBOX_URL=http://127.0.0.1:5000

# ===========================================
# OPTIONAL: Advanced Configuration
# ===========================================

# Database-specific configurations (auto-discovered if not set)
# BOOKREVIEW_DB_TYPE=sqlite
# BOOKREVIEW_DB_PATH=/path/to/bookreview.db
# YELP_DB_TYPE=mongodb
# USER_DATABASE_DB_TYPE=duckdb
# USER_DATABASE_DB_PATH=/path/to/yelp_user.db

# Sandbox configuration
SANDBOX_URL=

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================

# 1. Copy this file:
#    cp .env.example .env

# 2. Edit .env and add your API key:
#    - Get OpenRouter key: https://openrouter.ai/keys
#    - OR get Anthropic key: https://console.anthropic.com/

# 3. Start required services:
#    docker run -d --name team-dab-postgres -e POSTGRES_DB=bookreview_db -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=teampalm -p 5432:5432 postgres:15
#    docker run -d --name team-dab-mongo -p 27017:27017 mongo:6.0

# 4. Test your setup:
#    uv run python run_agent.py --dataset bookreview --query query_bookreview_benchmark/query1/query.json --iterations 5 --root_name test_run

# ===========================================
# TROUBLESHOOTING
# ===========================================

# If you get "database connection refused":
# - Check Docker containers: docker ps
# - Verify ports: netstat -tlnp | grep -E '(5432|27017)'

# If you get "API key error":
# - Check your API key is correct
# - Verify you have credits/balance

# If you get "LoopDetector error":
# - Clear Python cache: find . -name "__pycache__" -type d -exec rm -rf {} +

